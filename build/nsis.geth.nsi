/*******************************************************************************
 * Script Name: PopulateDeviceUpdateDetails_V4.sql
 * Description: Batch insert/update device update details and supported devices
 *              for iOS, tvOS, and macOS platforms
 * Date:        12-Feb-2026
 * Notes:       This script uses table-valued parameters to efficiently insert
 *              device update information and their supported device models
 ***********************************************************************/

-- ============================================================================
-- Table Variables Declaration
-- ============================================================================
-- Declare table variable for device updates (iOS, tvOS, macOS)

-- Taking Backup of DeviceUpdate, DeviceUpdateSupportedDeviceModelMap, SupportedDeviceModel Table

IF OBJECT_ID('deviceUpdate.DeviceUpdateSupportedDeviceModelMap_Backup_AAPP_21253', 'U') IS NOT NULL
    DROP TABLE deviceUpdate.DeviceUpdateSupportedDeviceModelMap_Backup_AAPP_21253;
	
IF OBJECT_ID('deviceUpdate.SupportedDeviceModel_Backup_AAPP_21253', 'U') IS NOT NULL
    DROP TABLE deviceUpdate.SupportedDeviceModel_Backup_AAPP_21253;
	
IF OBJECT_ID('deviceUpdate.DeviceUpdate_Backup_AAPP_21253', 'U') IS NOT NULL
    DROP TABLE deviceUpdate.DeviceUpdate_Backup_AAPP_21253;	

 SELECT * INTO [deviceUpdate].[DeviceUpdateSupportedDeviceModelMap_Backup_AAPP_21253] FROM [deviceUpdate].[DeviceUpdateSupportedDeviceModelMap] 
 SELECT * INTO [deviceUpdate].[SupportedDeviceModel_Backup_AAPP_21253] FROM [deviceUpdate].[SupportedDeviceModel]
 SELECT * INTO [deviceUpdate].[DeviceUpdate_Backup_AAPP_21253] FROM [deviceUpdate].[DeviceUpdate]

DECLARE @deviceUpdates deviceUpdate.DeviceUpdates_DataType;

